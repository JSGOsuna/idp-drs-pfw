generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("postgresql://d_rayado_user:mRK12waBxnUZ63uQvpCelcNNtsSEddvy@dpg-d4flporuibrs73bn8f90-a.ohio-postgres.render.com/d_rayado?sslmode=no-verify")
}

model Employee {
  id       Int    @id @default(autoincrement())
  name     String
  password String
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  slug     String
  products Product[]
}

model Product {
  id         Int      @id @default(autoincrement())
  name       String
  price      Float
  image      String
  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])
}
